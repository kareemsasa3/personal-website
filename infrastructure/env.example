# =============================================================================
# PORTFOLIO ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update the values according to your setup
# cp env.example .env

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
# Your primary domain name (e.g., yourdomain.com)
DOMAIN_NAME=your-domain.com

# Email for SSL certificate notifications
SSL_EMAIL=your-email@example.com

# Frontend Image
WEB_IMAGE=ghcr.io/username/personal-website/web:build-id

# =============================================================================
# WEB FRONTEND CONFIGURATION
# =============================================================================
# Frontend environment
WEB_NODE_ENV=production

# =============================================================================
# NGINX CONFIGURATION
# =============================================================================
# Nginx ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
# Docker network configuration
DOCKER_NETWORK_NAME=portfolio-network

# Container resource limits
NGINX_MEMORY_LIMIT=256M
NGINX_CPU_LIMIT=0.5
WEB_MEMORY_LIMIT=512M
WEB_CPU_LIMIT=1.0

# Grafana admin credentials for the monitoring stacks
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Development environment overrides
DEV_NODE_ENV=development
